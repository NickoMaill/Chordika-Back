{
    "name": "harmoniq",
    "version": "1.0.0",
    "description": "Backend Server of the musical utility app Harmoniq",
    "main": "src/app.ts",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev": "cross-env NODE_ENV=development nodemon",
        "build": "chmod +x ./buildCommand.sh && ./buildCommand.sh",
        "build-scripts": "tsc --project ./tsconfig.script.json",
        "docker": "docker-compose --env-file .env.development.local up -d",
        "start": "node dist/index.js",
        "format": "prettier --write \"**/*.{json,ts,tsx,scss,yml}\"",
        "lint": "eslint . --config ./eslint.config.mjs --ext ts,tsx --report-unused-disable-directives"
    },
    "keywords": [
        "music",
        "grilles",
        "musique",
        "song",
        "cover"
    ],
    "author": "Nicolas Maillols",
    "license": "ISC",
